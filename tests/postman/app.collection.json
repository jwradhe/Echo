{
  "info": {
    "name": "Echo (Newman) - Core + Follow flow",
    "_postman_id": "11111111-1111-1111-1111-111111111111",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:5001"
    },
    {
      "key": "username",
      "value": ""
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "password",
      "value": ""
    },
    {
      "key": "echoText",
      "value": ""
    },
    {
      "key": "targetUsername",
      "value": ""
    },
    {
      "key": "targetEmail",
      "value": ""
    },
    {
      "key": "targetPassword",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1) POST /register (primary user)",
      "protocolProfileBehavior": {
        "followRedirects": false
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "display_name",
              "value": "Newman User",
              "type": "text"
            },
            {
              "key": "username",
              "value": "{{username}}",
              "type": "text"
            },
            {
              "key": "email",
              "value": "{{email}}",
              "type": "text"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const stamp = Date.now();",
              "const username = `newman_user_${stamp}`;",
              "const email = `newman_user_${stamp}@example.com`;",
              "const password = 'TestPassword123';",
              "const echoText = `Newman Echo ${stamp}`;",
              "",
              "pm.collectionVariables.set('username', username);",
              "pm.collectionVariables.set('email', email);",
              "pm.collectionVariables.set('password', password);",
              "pm.collectionVariables.set('echoText', echoText);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 302 (redirect)', function () {",
              "  pm.expect(pm.response.code).to.eql(302);",
              "});",
              "",
              "pm.test('Redirects to /dashboard (or includes it)', function () {",
              "  const loc = pm.response.headers.get('Location') || '';",
              "  pm.expect(loc).to.include('/dashboard');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2) POST /api/posts (create post as primary)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"{{echoText}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.expect(pm.response.code).to.eql(201);",
              "});",
              "",
              "pm.test('Has created post id', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.post_id).to.be.a('string');",
              "  pm.collectionVariables.set('postId', json.post_id);",
              "});",
              "",
              "pm.test('Created content matches', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.content).to.eql(pm.collectionVariables.get('echoText'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3) POST /logout (primary user)",
      "protocolProfileBehavior": {
        "followRedirects": false
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
