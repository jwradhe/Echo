    },
    {
      "name": "7) POST /api/profile/:username/follow",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/profile/{{targetUsername}}/follow",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profile",
            "{{targetUsername}}",
            "follow"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Follow success true', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.is_following).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8) GET /api/profile/:username/follow",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/{{targetUsername}}/follow",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profile",
            "{{targetUsername}}",
            "follow"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Follow status is true', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.is_following).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9) GET /api/profile/:username (target has follower)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/{{targetUsername}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profile",
            "{{targetUsername}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Target username matches', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.username).to.eql(pm.collectionVariables.get('targetUsername'));",
              "});",
              "",
              "pm.test('Followers count incremented', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(Number(json.followers_count)).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}