{
  "title": "Echo Monitoring",
  "uid": "echo-monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum(rate(flask_http_request_total[1m]))",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Felrate (5xx req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum(rate(flask_http_request_total{status=~\"5..\"}[1m]))",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 0.01 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Medianlatens (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.5, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latens (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 2000 }
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "MySQL connections",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "mysql_global_status_threads_connected",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "MySQL frågor/s",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "rate(mysql_global_status_queries[1m])",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP requests per sekund per statuskod",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{status=~\"2..\"}[1m]))",
          "legendFormat": "2xx", "refId": "A"
        },
        {
          "expr": "sum(rate(flask_http_request_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx", "refId": "B"
        },
        {
          "expr": "sum(rate(flask_http_request_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx", "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latens p50 / p95 / p99 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p99", "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Request rate per endpoint (top endpoints)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "topk(10, sum(rate(flask_http_request_total[1m])) by (endpoint))",
        "legendFormat": "{{endpoint}}", "refId": "A"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "MySQL connections",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "Aktiva", "refId": "A"
        },
        {
          "expr": "mysql_global_variables_max_connections",
          "legendFormat": "Max", "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "MySQL frågor per sekund",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries[1m])",
          "legendFormat": "Queries/s", "refId": "A"
        },
        {
          "expr": "rate(mysql_global_status_slow_queries[1m])",
          "legendFormat": "Slow queries/s", "refId": "B"
        }
      ]
    }
  ]
}
