# ===================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===================================================================
# This file should be renamed to .env and deployed to production
# NEVER commit this file to version control with real credentials
# ===================================================================

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_SECRET_KEY=your-super-secure-random-secret-key-change-this
PORT=5000

# MySQL Database Configuration (REQUIRED - must be set)
# Use a dedicated database server, not localhost
# Consider using AWS RDS, Azure Database, or similar managed service
MYSQL_HOST=your-production-database-host.example.com
MYSQL_PORT=3306
MYSQL_USER=echo_app_user
MYSQL_PASSWORD=your-super-secure-database-password-change-this
MYSQL_ROOT_PASSWORD=your-super-secure-root-password-change-this-if-using-compose-mysql
MYSQL_DATABASE=EchoDB

# Connection Pool Configuration
# Adjust based on your application's concurrency requirements
# For production: balance between connection reuse and resource usage
MYSQL_POOL_SIZE=20
MYSQL_POOL_MAX_OVERFLOW=10
MYSQL_POOL_TIMEOUT=30

# Logging Configuration
# Production should use WARNING level to reduce log volume
# Consider using a log aggregation service (ELK, Splunk, CloudWatch, etc.)
LOG_LEVEL=WARNING
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password-change-this

# Session Configuration
PERMANENT_SESSION_LIFETIME_DAYS=7
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# Reverse proxy / forwarded headers
# Set to the number of trusted proxies in front of the app.
TRUSTED_PROXY_COUNT=1
